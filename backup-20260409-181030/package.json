{
  "name": "image-background-remover",
  "version": "1.0.0",
  "description": "Cloudflare部署的图片背景去除工具，使用Remove.bg API，无存储架构",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy ./dist",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write ."
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8"
  },
  "keywords": [
    "background-remover",
    "cloudflare",
    "remove-bg",
    "react",
    "image-processing"
  ],
  "author": "莹莹子",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crstalhelen527/image-background-remover.git"
  },
  "bugs": {
    "url": "https://github.com/crstalhelen527/image-background-remover/issues"
  },
  "homepage": "https://image-background-remover.pages.dev"
}